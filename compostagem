<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Guia de Compostagem Escolar e Caseira</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    background:#f4fdf4;
    color:#333;
    line-height:1.6;
}

header{
    background:linear-gradient(135deg,#2e7d32,#4caf50);
    color:white;
    text-align:center;
    padding:40px 20px;
}

header h1{
    font-size:2.5rem;
}

header p{
    margin-top:10px;
}

nav{
    background:#1b5e20;
    padding:12px;
    text-align:center;
}

nav a{
    color:white;
    text-decoration:none;
    margin:0 15px;
    font-weight:bold;
}

section{
    max-width:1100px;
    margin:auto;
    padding:40px 20px;
}

h2{
    color:#2e7d32;
    margin-bottom:20px;
}

.cards{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:20px;
}

.card{
    background:white;
    padding:20px;
    border-radius:12px;
    box-shadow:0 3px 10px rgba(0,0,0,0.1);
    transition:0.3s;
}

.card:hover{
    transform:translateY(-5px);
}

.card span{
    font-size:2rem;
}

.passos{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
}

.passo{
    background:white;
    padding:20px;
    border-left:6px solid #4caf50;
    border-radius:10px;
}

.calculadora{
    background:white;
    padding:30px;
    border-radius:15px;
    box-shadow:0 5px 15px rgba(0,0,0,0.1);
}

input{
    width:100%;
    padding:12px;
    margin:10px 0 20px;
    border:1px solid #ccc;
    border-radius:8px;
}

button{
    background:#43a047;
    color:white;
    border:none;
    padding:12px 25px;
    border-radius:8px;
    cursor:pointer;
    font-size:1rem;
}

button:hover{
    background:#2e7d32;
}

.resultado{
    margin-top:20px;
    padding:15px;
    background:#e8f5e9;
    border-radius:10px;
    font-weight:bold;
}

footer{
    background:#1b5e20;
    color:white;
    text-align:center;
    padding:20px;
    margin-top:40px;
}

.hero{
    text-align:center;
    padding:30px;
}

.hero img{
    width:100%;
    max-width:600px;
    border-radius:15px;
    margin-top:20px;
}

@media(max-width:600px){
    header h1{
        font-size:2rem;
    }
}
</style>
</head>
<body>

<header>
    <h1>🌱 Guia de Compostagem Escolar e Caseira</h1>
    <p>Transforme restos de alimentos em adubo orgânico e reduza o lixo enviado aos aterros.</p>
</header>

<nav>
    <a href="#sobre">Sobre</a>
    <a href="#passos">Passo a Passo</a>
    <a href="#beneficios">Benefícios</a>
    <a href="#calculadora">Calculadora</a>
</nav>

<section class="hero">
    <h2>Compostar é cuidar do planeta!</h2>
    <p>
        A compostagem transforma resíduos orgânicos em adubo natural,
        ajudando escolas, famílias e comunidades a reduzirem a produção de lixo.
    </p>
</section>

<section id="sobre">
    <h2>📚 O que é Compostagem?</h2>
    <p>
        Compostagem é o processo natural de decomposição de resíduos orgânicos,
        como cascas de frutas, legumes, folhas secas e restos de alimentos.
        O resultado é um adubo rico em nutrientes para plantas e hortas.
    </p>
</section>

<section id="passos">
    <h2>🪴 Passo a Passo</h2>

    <div class="passos">

        <div class="passo">
            <h3>1. Separe os resíduos</h3>
            <p>
                Reúna cascas de frutas, verduras, borra de café e restos vegetais.
            </p>
        </div>

        <div class="passo">
            <h3>2. Adicione material seco</h3>
            <p>
                Use folhas secas, serragem ou papel sem tinta para equilibrar a umidade.
            </p>
        </div>

        <div class="passo">
            <h3>3. Monte camadas</h3>
            <p>
                Alterne resíduos úmidos e secos dentro da composteira.
            </p>
        </div>

        <div class="passo">
            <h3>4. Revolva regularmente</h3>
            <p>
                Misture os materiais para melhorar a oxigenação.
            </p>
        </div>

        <div class="passo">
            <h3>5. Aguarde a decomposição</h3>
            <p>
                Em algumas semanas ou meses o composto estará pronto.
            </p>
        </div>

        <div class="passo">
            <h3>6. Utilize o adubo</h3>
            <p>
                Aplique em jardins, vasos ou hortas escolares.
            </p>
        </div>

    </div>
</section>

<section id="beneficios">
    <h2>🌍 Benefícios da Compostagem</h2>

    <div class="cards">

        <div class="card">
            <span>♻️</span>
            <h3>Menos lixo</h3>
            <p>Reduz a quantidade de resíduos enviados aos aterros.</p>
        </div>

        <div class="card">
            <span>🌱</span>
            <h3>Adubo natural</h3>
            <p>Produz fertilizante rico em nutrientes.</p>
        </div>

        <div class="card">
            <span>🏫</span>
            <h3>Educação ambiental</h3>
            <p>Estimula práticas sustentáveis na escola e em casa.</p>
        </div>

        <div class="card">
            <span>🌎</span>
            <h3>Menos emissão de gases</h3>
            <p>Diminui a produção de metano em aterros sanitários.</p>
        </div>

    </div>
</section>

<section id="calculadora">
    <h2>🧮 Calculadora de Resíduos Evitados</h2>

    <div class="calculadora">

        <label>Quantidade média de resíduos orgânicos por dia (kg)</label>
        <input type="number" id="residuos" placeholder="Ex: 2">

        <label>Número de dias compostando</label>
        <input type="number" id="dias" placeholder="Ex: 30">

        <button onclick="calcular()">Calcular</button>

        <div class="resultado" id="resultado">
            Preencha os dados para calcular.
        </div>

    </div>
</section>

<footer>
    <p>🌱 Guia de Compostagem Escolar e Caseira | Educação Ambiental e Sustentabilidade</p>
</footer>

<script>
function calcular(){

    let residuos = parseFloat(document.getElementById("residuos").value);
    let dias = parseInt(document.getElementById("dias").value);

    if(isNaN(residuos) || isNaN(dias) || residuos <= 0 || dias <= 0){
        document.getElementById("resultado").innerHTML =
        "⚠️ Insira valores válidos.";
        return;
    }

    let total = residuos * dias;

    // estimativa de composto gerado (~40%)
    let adubo = total * 0.4;

    document.getElementById("resultado").innerHTML =
    `
    ✅ Você evitou que <strong>${total.toFixed(1)} kg</strong> de resíduos fossem enviados aos aterros.<br><br>

    🌿 Estimativa de adubo produzido:
    <strong>${adubo.toFixed(1)} kg</strong>.
    `;
}
</script>

</body>
</html>
